# Path to the docs folder to index (absolute or relative to project root)
DOCS_PATH=./docs

# Ollama endpoint
OLLAMA_URL=http://localhost:11434

# Embedding model
EMBEDDING_MODEL=qwen3-embedding:0.6b

# Embedding dimensions (qwen3-embedding supports 32-1024 via Matryoshka; use 1024 for best quality)
EMBEDDING_DIMS=1024

# Data storage path (for Orama index + SQLite metadata)
DATA_PATH=.sextant

# Watch for file changes and auto-reindex (true/false)
WATCH_ENABLED=true

# Chunk size limits
MAX_CHUNK_TOKENS=512
CHUNK_OVERLAP_LINES=2

# Search defaults
DEFAULT_TOP_K=10

# Hybrid search weights (0.0-1.0, must sum to 1.0)
HYBRID_WEIGHT_TEXT=0.3
HYBRID_WEIGHT_VECTOR=0.7
